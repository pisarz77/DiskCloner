<Window x:Class="DiskCloner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Disk Cloner - System Disk Clone Tool" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="28" FontWeight="Bold" Text="Disk Cloner"/>
            <TextBlock FontSize="14" Foreground="Gray" Text="Clone your Windows system disk to a new drive"/>
        </StackPanel>

        <!-- Warning Banner -->
        <Border Grid.Row="1" Background="#FFF4D7" BorderBrush="#FFD700" BorderThickness="2" CornerRadius="5" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#8B0000" Text="⚠ WARNING: Destructive Operation"/>
                <TextBlock FontSize="14" Foreground="#8B0000" TextWrapping="Wrap" Margin="0,5,0,0"
                           Text="This will completely overwrite the target disk. All data on the target will be permanently lost. Verify your selection carefully."/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="2" Grid.RowSpan="2" x:Name="MainTabControl">
            <!-- Step 1: Select Disks -->
            <TabItem Header="1. Select Disks">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Source Disk (System Disk)" Margin="0,0,0,10"/>
                        <ComboBox x:Name="SourceDiskComboBox" DisplayMemberPath="DisplayText" SelectedValuePath="DiskNumber"
                                  FontSize="14" Padding="10" Margin="0,0,0,20" SelectionChanged="SourceDiskComboBox_SelectionChanged"/>
                        <Button Content="Refresh Disks" Click="RefreshDisksButton_Click" HorizontalAlignment="Left"/>

                        <Separator Margin="0,30,0,30"/>

                        <TextBlock FontSize="18" FontWeight="Bold" Text="Target Disk" Margin="0,0,0,10"/>
                        <ComboBox x:Name="TargetDiskComboBox" DisplayMemberPath="DisplayText" SelectedValuePath="DiskNumber"
                                  FontSize="14" Padding="10" Margin="0,0,0,20" SelectionChanged="TargetDiskComboBox_SelectionChanged"/>
                        <Button Content="Refresh Disks" Click="RefreshDisksButton_Click" HorizontalAlignment="Left"/>

                        <Separator Margin="0,30,0,30"/>

                        <!-- Partitions List -->
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Partitions to Clone" Margin="0,0,0,10"/>
                        <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Background="White">
                            <ListBox x:Name="PartitionsListBox" FontSize="13" MaxHeight="250">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}" Margin="2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Selected Disks Summary -->
                        <Border BorderBrush="Gray" BorderThickness="1" Padding="15" Margin="0,20,0,0" Background="#F0F0F0">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Selected Summary"/>
                                <TextBlock x:Name="SummarySourceTextBlock" Text="Source: Not selected" Margin="0,5,0,0"/>
                                <TextBlock x:Name="SummaryTargetTextBlock" Text="Target: Not selected" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 2: Options -->
            <TabItem Header="2. Options">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Cloning Options" Margin="0,0,0,20"/>

                        <!-- VSS Option -->
                        <CheckBox x:Name="UseVssCheckBox" IsChecked="True" Margin="0,0,0,15">
                            <TextBlock Text="Use Volume Shadow Copy Service (VSS)" TextWrapping="Wrap"/>
                        </CheckBox>
                        <TextBlock FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="25,0,0,20"
                                   Text="Creates a consistent snapshot of the source disk. Recommended for system clones."/>

                        <!-- Verification Option -->
                        <CheckBox x:Name="VerifyIntegrityCheckBox" IsChecked="True" Margin="0,0,0,15">
                            <TextBlock Text="Verify data integrity after copy" TextWrapping="Wrap"/>
                        </CheckBox>

                        <!-- Full Hash Verification -->
                        <CheckBox x:Name="FullHashCheckBox" IsChecked="False" Margin="25,0,0,20">
                            <TextBlock Text="Full hash verification (slower but more thorough)" TextWrapping="Wrap" FontSize="13"/>
                        </CheckBox>
                        <TextBlock FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="25,0,0,20"
                                   Text="When unchecked, only samples are verified for faster operation."/>

                        <!-- Expand Partition Option -->
                        <CheckBox x:Name="AutoExpandCheckBox" IsChecked="True" Margin="0,0,0,15">
                            <TextBlock Text="Automatically expand C: partition after clone" TextWrapping="Wrap"/>
                        </CheckBox>
                        <TextBlock FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="25,0,0,20"
                                   Text="If target disk is larger than source, the Windows partition will be expanded to use all available space."/>

                        <!-- Smart Copy Option -->
                        <CheckBox x:Name="SmartCopyCheckBox" IsChecked="True" Margin="0,0,0,15">
                            <TextBlock Text="Smart copy (skip free sectors)" TextWrapping="Wrap"/>
                        </CheckBox>
                        <TextBlock FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="25,0,0,20"
                                   Text="Only copies actual data on NTFS partitions. Faster and required for shrinking to a smaller target disk."/>

                        <!-- Allow Smaller Target Option -->
                        <CheckBox x:Name="AllowSmallerTargetCheckBox" IsChecked="False" Margin="0,0,0,15">
                            <TextBlock Text="Allow smaller target disk" TextWrapping="Wrap"/>
                        </CheckBox>
                        <TextBlock FontSize="12" Foreground="Red" TextWrapping="Wrap" Margin="25,0,0,20"
                                   Text="⚠ WARNING: Cloning to a smaller disk is risky and may fail. Only use if you know the data will fit."/>

                        <!-- IO Buffer Size -->
                        <TextBlock Text="I/O Buffer Size:" Margin="0,10,0,5"/>
                        <ComboBox x:Name="BufferSizeComboBox" Width="250" Margin="0,0,0,20" SelectedIndex="1">
                            <ComboBoxItem Content="16 MB"/>
                            <ComboBoxItem Content="64 MB" IsSelected="True"/>
                            <ComboBoxItem Content="128 MB"/>
                            <ComboBoxItem Content="256 MB"/>
                        </ComboBox>

                        <!-- Log Location -->
                        <TextBlock Text="Log file will be saved to:" Margin="0,10,0,5"/>
                        <TextBlock x:Name="LogFileTextBlock" Text="" Foreground="Blue" Margin="0,0,0,20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 3: Preview -->
            <TabItem Header="3. Preview &amp; Confirm">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Operation Preview" Margin="0,0,0,20"/>

                        <Border BorderBrush="Gray" BorderThickness="2" Padding="20" Background="#FFF8F0">
                            <TextBlock x:Name="PreviewTextBlock" Text="" TextWrapping="Wrap" FontFamily="Consolas" FontSize="13"/>
                        </Border>

                        <Button x:Name="PreviewButton" Content="Generate Preview" Click="PreviewButton_Click"
                                Margin="0,20,0,0" HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 4: Clone -->
            <TabItem Header="4. Clone">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Start Cloning" Margin="0,0,0,20"/>

                        <!-- Safety Warnings -->
                        <Border BorderBrush="Red" BorderThickness="2" Padding="15" Margin="0,0,0,20" Background="#FFF0F0">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="Red" Text="Final Safety Check"/>
                                <TextBlock Text="1. Verify source disk is correct (system disk)" Margin="0,10,0,0"/>
                                <TextBlock Text="2. Verify target disk is correct (USB drive)" Margin="0,5,0,0"/>
                                <TextBlock Text="3. Verify target has no important data (will be erased)" Margin="0,5,0,0"/>
                                <TextBlock Text="4. Ensure USB connection is stable" Margin="0,5,0,0"/>
                                <TextBlock Text="5. Close all other applications" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Confirmation Section -->
                        <TextBlock FontSize="16" FontWeight="Bold" Text="Type 'CLONE' to confirm:" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBox x:Name="ConfirmationTextBox" Width="150" Margin="0,0,10,0" TextChanged="ConfirmationTextBox_TextChanged"/>
                            <Button x:Name="CloneButton" Content="Start Clone" IsEnabled="False"
                                    Click="CloneButton_Click" Background="#FF4CAF50" Foreground="White"/>
                        </StackPanel>

                        <!-- Progress Section -->
                        <Border x:Name="ProgressBorder" BorderBrush="Gray" BorderThickness="1" Padding="20" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="StageTextBlock" FontSize="16" FontWeight="Bold" Text=""/>
                                <ProgressBar x:Name="ProgressBar" Height="25" Margin="0,10,0,10" Minimum="0" Maximum="100"/>
                                <TextBlock x:Name="ProgressTextBlock" Text=""/>
                                <TextBlock x:Name="ThroughputTextBlock" Text="" Margin="0,5,0,0" Foreground="Blue"/>
                                <TextBlock x:Name="RemainingTimeTextBlock" Text="" Margin="0,5,0,0" Foreground="Gray"/>

                                <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click"
                                        Margin="0,15,0,0" HorizontalAlignment="Left" Background="#FFF44336" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- Results Section -->
                        <Border x:Name="ResultsBorder" BorderThickness="1" Padding="20" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="ResultsTitleTextBlock" FontSize="18" FontWeight="Bold" Text=""/>
                                <TextBlock x:Name="ResultsTextBlock" Text="" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                <Button x:Name="ViewLogsButton" Content="View Logs" Click="ViewLogsButton_Click"
                                        Margin="0,15,0,0" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
